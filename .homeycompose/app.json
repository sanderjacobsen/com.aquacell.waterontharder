{
  "id": "com.aquacell.waterontharder",
  "version": "1.0.0",
  "compatibility": ">=12.2.0",
  "sdk": 3,
  "name": {
    "en": "AquaCell",
    "nl": "AquaCell"
  },
  "description": {
    "en": "Monitor your AquaCell water softener",
    "nl": "Monitor uw AquaCell waterontharder"
  },
  "category": [
    "appliances"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Community",
    "email": "info@example.com"
  },
  "drivers": [
    {
      "name": {
        "en": "AquaCell Water Softener",
        "nl": "AquaCell Waterontharder"
      },
      "class": "sensor",
      "capabilities": [
        "measure_battery"
      ],
      "images": {
        "small": "/drivers/aquacell_softener/assets/images/small.png",
        "large": "/drivers/aquacell_softener/assets/images/large.png",
        "xlarge": "/drivers/aquacell_softener/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "usernameLabel": {
              "en": "Email address",
              "nl": "E-mailadres"
            },
            "usernamePlaceholder": {
              "en": "your@email.com",
              "nl": "uw@email.nl"
            },
            "passwordLabel": {
              "en": "Password",
              "nl": "Wachtwoord"
            }
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "id": "salt_left",
          "type": "label",
          "label": {
            "en": "Salt Left Side",
            "nl": "Zout Linkerkant"
          },
          "value": ""
        },
        {
          "id": "salt_right",
          "type": "label",
          "label": {
            "en": "Salt Right Side",
            "nl": "Zout Rechterkant"
          },
          "value": ""
        },
        {
          "id": "days_left",
          "type": "label",
          "label": {
            "en": "Days Until Empty",
            "nl": "Dagen Tot Leeg"
          },
          "value": ""
        },
        {
          "id": "last_update",
          "type": "label",
          "label": {
            "en": "Last Update",
            "nl": "Laatste Update"
          },
          "value": ""
        }
      ],
      "id": "aquacell_softener"
    }
  ]
}